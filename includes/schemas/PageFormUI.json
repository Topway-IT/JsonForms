{
	"@type": "JsonForms default schema",
	"x-compact": true,
	"x-css-class": "jsonforms-outerform",
	"required": [],
	"properties": {
		"form": {
			"type": "object",
			"x-compact": true,
			"x-css-class": "jsonforms-innerform",
			"x-layout": "booklet",
			"x-layout-config": {
				"outlined": false
			},
			"properties": {
				"editor": {
					"type": "string",
					"x-format": "json",
					"x-compact": true,
					"x-input": "jsonforms",
					"x-input-config": {
						"schema": ""
					}
				},
				"options": {
					"type": "object",
					"x-compact": true,
					"x-css-class": "jsonforms-innerform-options",
					"properties": {
						"title": {
							"type": "string",
							"minLength": 1,
							"x-input": "title"
						},
						"data_slot_role": {
							"type": "string",
							"title": "data slot's role",
							"description": "Target slot role for form data",
							"default": "",
							"x-enum-source": [
								{
									"source": "jsonSlotsSource"
								}
							]
						},
						"main_slot_content_model": {
							"title": "content model of main slot",
							"type": "string",
							"default": "wikitext",
							"x-enum-source": [
								{
									"source": "contentModelsSource"
								}
							],
							"x-visibility": {
								"data_slot": {
									"op": "!=",
									"value": "main"
								}
							}
						},
						"main_slot_content": {
							"type": "string",
							"format": "textarea",
							"x-visibility": {
								"data_slot": {
									"op": "!=",
									"value": "main"
								}
							}
						},
						"categories": {
							"type": "array",
							"items": {
								"type": "string",
								"x-input": "categorymultiselect"
							}
						},
						"summary": {
							"type": "string",
							"x-visibility": {
								"data_slot": {
									"op": "!=",
									"value": "main"
								}
							}
						},
						"minor": {
							"type": "boolean",
							"description": "",
							"x-wikitext-description": "This is a [https://www.mediawiki.org/wiki/Help:Minor_edit minor edit]",
							"x-input": "checkbox",
							"x-visibility": {
								"data_slot": {
									"op": "!=",
									"value": "main"
								}
							}
						}
					},
					"required": []
				}
			}
		},
		"captcha": {
			"x-compact": true,
			"x-css-class": "jsonforms-outerform-captcha",
			"type": "string",
			"format": "captcha"
		},
		"buttons": {
			"x-compact": true,
			"x-css-class": "jsonforms-outerform-buttons",
			"properties": {
				"validate": {
					"type": "null",
					"x-format": "button",
					"x-button-action": "outerFormNavButton",
					"x-input-config": {
						"flags": ["primary", "progressive"]
					}
				},
				"submit": {
					"type": "null",
					"x-format": "button",
					"x-button-action": "outerFormNavButton",
					"x-input-config": {
						"flags": ["primary", "progressive"]
					}
				},
				"goback": {
					"type": "null",
					"x-format": "button",
					"x-button-action": "outerFormNavButton",
					"x-input-config": {
						"icon": "arrowPrevious"
					}
				}
			}
		}
	}
}

