{
	"@type": "JsonForms default schema",
	"$id": "PageFormUI",
	"x-compact": true,
	"x-css-class": "jsonforms-outerform",
	"type": "object",
	"properties": {
		"header": {
			"x-compact": false,
			"x-css-class": "jsonforms-outerform-header",
			"title": "",
			"description": "",
			"properties": {
				"buttons": {
					"x-compact": true,
					"properties": {
						"goback": {
							"type": "null",
							"title": "go back",
							"x-format": "button",
							"x-button-action": "outerFormNavButton",
							"x-input-config": {
								"icon": "arrowPrevious",
								"framed": false,
								"flags": [
									"invert", "primary"
								],
								"classes": [ "jsonforms-button-white-color" ]
							}
						}
					}
				}
			}
		},
		"form": {
			"type": "object",
			"x-compact": true,
			"x-css-class": "jsonforms-innerform",
			"x-layout": "booklet",
			"x-layout-config": {
				"outlined": false
			},
			"properties": {
				"editor": {
					"type": "string",
					"x-format": "json",
					"x-compact": true,
					"x-input": "jsonforms",
					"x-input-config": {
						"schema": ""
					}
				},
				"options": {
					"type": "object",
					"x-compact": true,
					"x-css-class": "jsonforms-innerform-options",
					"properties": {
						"title": {
							"type": "string",
							"minLength": 1,
							"x-input": "title"
						},
						"freetext_content_model": {
							"type": "string",
							"x-enum-provider": "contentModels"
						},
						"freetext": {
							"type": "string",
							"x-format": "textarea"
						},
						"categories": {
							"type": "array",
							"items": {
								"type": "string",
								"x-input": "categorymultiselect"
							}
						},
						"summary": {
							"type": "string",
							"x-dependency": {
								"data_slot": {
									"op": "!=",
									"value": "main"
								}
							}
						},
						"minor": {
							"type": "boolean",
							"description": "",
							"x-wikitext-description": "This is a [https://www.mediawiki.org/wiki/Help:Minor_edit minor edit]",
							"x-input": "checkbox",
							"x-dependency": {
								"data_slot": {
									"op": "!=",
									"value": "main"
								}
							}
						}
					},
					"required": []
				}
			}
		},
		"captcha": {
			"x-compact": true,
			"x-css-class": "jsonforms-outerform-captcha",
			"type": "string",
			"format": "captcha"
		},
		"footer": {
			"x-compact": true,
			"x-css-class": "jsonforms-outerform-footer",
			"properties": {
				"buttons": {
					"x-compact": true,
					"x-css-class": "jsonforms-outerform-buttons",
					"properties": {
						"validate": {
							"type": "null",
							"x-format": "button",
							"x-button-action": "outerFormNavButton",
							"x-input-config": {
								"flags": ["primary", "progressive"]
							}
						},
						"submit": {
							"type": "null",
							"x-format": "button",
							"x-button-action": "outerFormNavButton",
							"x-input-config": {
								"flags": ["primary", "progressive"]
							}
						}
					}
				}
			}
		}
	}
}

