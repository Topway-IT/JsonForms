{
	"definitions": {
		"editor_wikieditor": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input": "wikieditor"
		},
		"editor_codeeditor": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input": "codeeditor"
		},
		"editor_visualeditor": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input": "visualeditor"
		},
		"editor_jsoneditor": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input": "jsoneditor"
		},
		"editor_jsonforms": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input": "jsonforms",
			"x-input-config": {
				"schema": "JsonSchema:Core/SelectSchema"
			}
		},
		"editor_source": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input-config": {
				"autosize": true,
				"rows": 6
			}
		},
		"selectSchema": {
			"type": "object",
			"x-compact": true,
			"$id": "SelectSchema",
			"x-watch": "schema",
			"properties": {
				"schema": {
					"type": "string",
					"title": "JSON Schema",
					"description": "",
					"default": "",
					"minLength": 1,
					"x-wikitext-description": "manage schemas [[Special:JsonFormsManage/Schemas|here]]",
					"x-format": "autocomplete",
					"x-input": "OO.ui.DropdownInputWidget",
					"x-enum-provider": "jsonSchemas"
				},
				"editor_": {
					"x-compact": "true",
					"x-collapsible": "true",
					"x-watch": "schema",
					"links": [
						{
							"rel": "describedBy",
							"href": "JsonSchema:{{schema}}",
							"x-destroy-values-on-switch": true
						}
					]
				}
			}
		},
		"article": {
			"x-compact": true,
			"properties": {
				"title": {
					"type": "string",
					"x-input": "mw.widgets.TitleInputWidget"
				},
				"content_model": {
					"type": "string",
					"title": "Content model",
					"default": "wikitext",
					"x-watch": "role",
					"x-enum-provider": "contentModelByRole"
				},
				"editor": {
					"type": "string",
					"title": "Editor",
					"default": "source",
					"x-watch": "content_model",
					"x-enum-provider": "editorByContentModel"
				},
				"content": {
					"type": "string",
					"x-watch": "editor",
					"links": [
						{
							"rel": "describedBy",
							"href": "#/definitions/editor_{{editor}}"
						}
					]
				},
				"categories": {
					"type": "array",
					"items": {
						"type": "string",
						"x-input": "categorymultiselect"
					}
				}
			},
			"required": ["title"]
		}
	},
	"type": "object",
	"$id": "SimpleFormUI",
	"@type": "JsonForms default schema",
	"x-compact": true,
	"x-css-class": "jsonforms-outerform",
	"required": [],
	"properties": {
		"editor": {
			"oneOf": [
				{
					"type": "object",
					"title": "regular",
					"description": "Main slot only",
					"x-compact": true,
					"$ref": "#/definitions/article"
				},
				{
					"x-compact": true,
					"title": "combined",
					"description": "Main slot with human-readable content and additional slot for data",
					"type": "object",
					"x-layout": "booklet",
					"x-layout-config": {
						"outlined_": false
					},
					"properties": {
						"main": {
							"$ref": "#/definitions/article"
						},
						"data": {
							"description": "Set a schema if this article is an instance of a class. For instance an article, a person, etc.",
							"$ref": "#/definitions/selectSchema"
						},
						"options": {
							"x-compact": true,
							"properties": {
								"show_infobox": {
									"type": "boolean",
									"title": "Show Infobox",
									"description": "Whether to show an infobox on the target page",
									"default": true
								},
								"infobox_template": {
									"type": "string",
									"title": "Infobox template",
									"description": "Template to use (leave empty for automatic generation)",
									"default": "",
									"x-input": "mw.widgets.TitleInputWidget",
									"x-input-config": {
										"namespace": 10
									},
									"x-dependency": {
										"path": "show_infobox",
										"op": "==",
										"value": true
									}
								}
							}
						}
					}
				},
				{
					"x-compact": true,
					"title": "data only",
					"required": ["title"],
					"allOf": [
						{
							"properties": {
								"title": {
									"type": "string",
									"x-input": "mw.widgets.TitleInputWidget"
								}
							}
						},
						{
							"$ref": "#/definitions/selectSchema"
						},
						{
							"properties": {
								"categories": {
									"type": "array",
									"items": {
										"type": "string",
										"x-input": "categorymultiselect"
									}
								}
							}
						}
					]
				}
			]
		},
		"footer": {
			"x-compact": true,
			"x-css-class": "jsonforms-outerform-footer",
			"properties": {
				"summary": {
					"type": "string"
				},
				"minor": {
					"type": "boolean",
					"title": "",
					"description": "",
					"x-wikitext-description": "This is a [https://www.mediawiki.org/wiki/Help:Minor_edit minor edit]",
					"x-input": "checkbox",
					"x-control-config": {
						"align": "inline"
					}
				},
				"buttons": {
					"type": "object",
					"x-layout": "horizontal",
					"x-compact": true,
					"x-css-class": "jsonforms-outerform-footer-buttons",
					"properties": {
						"submit": {
							"type": "null",
							"title": "Save changes",
							"x-format": "button",
							"x-button-action": "submitButton",
							"x-input-config": {
								"flags": ["primary", "progressive"]
							}
						},
						"cancel": {
							"type": "null",
							"title": "Cancel",
							"x-format": "button",
							"x-button-action": "cancelButton",
							"x-input-config": {
								"flags": ["destructive"]
							}
						}
					}
				}
			}
		}
	}
}

